#include <iostream>
using namespace std;

int main() {
    const int MAX_MOKINIU = 100;
    const int MAX_PAZYMIU = 10;

    string vardai[MAX_MOKINIU];
    int pazymiai[MAX_MOKINIU][MAX_PAZYMIU];
    int pazymiuKiekis[MAX_MOKINIU];

    int mokiniuKiekis = 0;
    int pasirinkimas;

    do {
        cout << "MENIU: \n";
        cout << "1. Prideti mokini\n";
        cout << "2. Rodyti visus\n";
        cout << "3. Atnaujinti pazymi\n";
        cout << "4. Pasalinti mokini\n";
        cout << "0. Baigti\n";
        cout << "Pasirinkimas: ";
        cin >> pasirinkimas;

        // Prideda mokinius
        if (pasirinkimas == 1) {
    int kiek;
    cout << "Kiek mokiniu norite prideti: ";
    cin >> kiek;

    for (int m = 0; m < kiek; m++) {
        if (mokiniuKiekis >= MAX_MOKINIU) {
            cout << "Pasiektas maksimalus mokiniu skaicius!\n";
            break;
        }

        cout << "\nIveskite " << m + 1 << "-ojo mokinio varda: ";
        cin >> vardai[mokiniuKiekis];

        cout << "Kiek pazymiu (max 10): ";
        cin >> pazymiuKiekis[mokiniuKiekis];

        if (pazymiuKiekis[mokiniuKiekis] > MAX_PAZYMIU)
            pazymiuKiekis[mokiniuKiekis] = MAX_PAZYMIU;

        if (pazymiuKiekis[mokiniuKiekis] < 0)
            pazymiuKiekis[mokiniuKiekis] = 0;

        for (int i = 0; i < pazymiuKiekis[mokiniuKiekis]; i++) {
            cout << "Pazymys " << i + 1 << ": ";
            cin >> pazymiai[mokiniuKiekis][i];
        }

        mokiniuKiekis++;
    }
}

        // Rodo mokinius
        else if (pasirinkimas == 2) {
            for (int i = 0; i < mokiniuKiekis; i++) {
                cout << vardai[i] << ": ";
                for (int j = 0; j < pazymiuKiekis[i]; j++) {
                    cout << pazymiai[i][j] << " ";
                }
                cout << endl;
            }
        }

        // Atnaujina mokinius
        else if (pasirinkimas == 3) {
            string vardas;
            cout << "Iveskite mokinio varda: ";
            cin >> vardas;

            for (int i = 0; i < mokiniuKiekis; i++) {
                if (vardai[i] == vardas) {
                    int nr;
                    cout << "Kuri pazymi keisti (1-" << pazymiuKiekis[i] << "): ";
                    cin >> nr;

                    cout << "Naujas pazymys: ";
                    cin >> pazymiai[i][nr - 1];
                }
            }
        }

        // Pasalinti
        else if (pasirinkimas == 4) {
            string vardas;
            cout << "Iveskite mokinio varda: ";
            cin >> vardas;

            for (int i = 0; i < mokiniuKiekis; i++) {
                if (vardai[i] == vardas) {

                    for (int j = i; j < mokiniuKiekis - 1; j++) {
                        vardai[j] = vardai[j + 1];
                        pazymiuKiekis[j] = pazymiuKiekis[j + 1];

                        for (int k = 0; k < 10; k++) {
                            pazymiai[j][k] = pazymiai[j + 1][k];
                        }
                    }

                    mokiniuKiekis--;
                    break;
                }
            }
        }

    } while (pasirinkimas != 0);

    return 0;
}
