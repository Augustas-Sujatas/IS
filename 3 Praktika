#include <iostream>
#include <fstream>
#include <string>
#include <iomanip>
#include <locale>
#include <windows.h>
using namespace std;

struct menuItemType {
    string menuItem;
    double menuPrice;
};

void getData(menuItemType menuList[], int &kiek) {

    ifstream failas("menu.txt");

    if (!failas) {
        cout << "Nepavyko atidaryti failo!" << endl;
        return;
    }

    kiek = 0;
    string eilute;

    // Skaito faila eilute po eilutes
    while (getline(failas, eilute)) {

        // Suranda paskutini TAB simboli eiluteje
        size_t paskutinisTarpas = eilute.find_last_of('\t');

        // Jei TAB simbolio nerado
        if (paskutinisTarpas == string::npos)

            // Tada iesko paskutinio paprasto tarpo
            paskutinisTarpas = eilute.find_last_of(' ');

        // Iskerpa teksta nuo pradzios iki paskutinio tarpo
        // Tai bus patiekalo pavadinimas
        menuList[kiek].menuItem =
            eilute.substr(0, paskutinisTarpas);

        // Iskerpa skaiciu po paskutinio tarpo
        // stod() pavercia string i double tipo skaiciu
        menuList[kiek].menuPrice =
            stod(eilute.substr(paskutinisTarpas + 1));

        kiek++; // Padidina patiekalu skaiciu
    }

    failas.close();
}

// Funkcija meniu parodymui ekrane
void showMenu(menuItemType menuList[], int kiek) {

    cout << "Pusryciu meniu:" << endl;

    // Ciklas eina per visus meniu elementus
    for (int i = 0; i < kiek; i++) {

    // Isveda numeri/kaina
        cout << i + 1 << ". "
             << menuList[i].menuItem << " - "
             << fixed << setprecision(2)
             << menuList[i].menuPrice << " EUR" << endl;
    }
}

// funkcija isvesti i receipt
void printCheck(menuItemType menuList[], int kiek,
                int pasirinktiKiekiai[], double suma) {

    double pvm = suma * 0.21;
    double galutine = suma + pvm;

    ofstream outFile("receipt.txt");


    cout << "\n Sveiki atvykę į restoraną \n" << endl;
    outFile << "Sveiki atvykę į restoraną \n";

    cout << fixed << setprecision(2);
    outFile << fixed << setprecision(2);

    for (int i = 0; i < kiek; i++) {
        if (pasirinktiKiekiai[i] > 0) {

            cout << pasirinktiKiekiai[i] << "  "
                 << menuList[i].menuItem << "   "
                 << menuList[i].menuPrice << "EUR" << endl;

            outFile << pasirinktiKiekiai[i] << "  "
                    << menuList[i].menuItem << "   "
                    << menuList[i].menuPrice << "EUR" << endl;
        }
    }

    cout << "\nMokesčiai (21%)   " << pvm << "EUR" << endl;
    cout << "Galutinė suma     " << galutine << "EUR" << endl;

    outFile << "\nMokesčiai (21%)   " << pvm << "EUR" << endl;
    outFile << "Galutinė suma     " << galutine << "EUR" << endl;

    outFile.close();
}

int main()  {


// konsolei rodytu lietuviskas raides
SetConsoleOutputCP(65001);
SetConsoleCP(65001);

    menuItemType menuList[50];

    int kiek;

    getData(menuList, kiek);

    showMenu(menuList, kiek);

    int pasirinkimas;
    int kiekis;
    double suma = 0;

    // masyvas pasirinkimams kiekiams saugoti
    int pasirinktiKiekiai[50] = {0};

    cout << "\nRinkis patiekalus (0 - baigti):" << endl;

    while (true) {

        cin >> pasirinkimas;

        if (pasirinkimas == 0) {
            break;
        }

        if (pasirinkimas < 1 || pasirinkimas > kiek) {

            cout << "Netinkamas pasirinkimas!" << endl;
            continue;
        }

        cout << "Kiek porciju?: ";
        cin >> kiekis;

        // saugo pasirinkimus
        pasirinktiKiekiai[pasirinkimas - 1] += kiekis;

        suma += menuList[pasirinkimas - 1].menuPrice * kiekis;

        cout << "Prideta!" << endl;
    }

    printCheck(menuList, kiek, pasirinktiKiekiai, suma); //spausdina ceki

    return 0;
}
